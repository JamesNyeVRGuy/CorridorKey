{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "type": "logs",
      "title": "Application Logs",
      "gridPos": { "h": 20, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "{job=\"corridorkey\"} | json | level=~\"$level\" | logger=~\"$logger\" | line_format \"{{.msg}}\"",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": false,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    },
    {
      "type": "timeseries",
      "title": "Log Volume by Level",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "sum by (level) (count_over_time({job=\"corridorkey\"} | json [$__interval]))",
          "legendFormat": "{{ level }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "error" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "warning" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "info" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["corridorkey", "logs"],
  "templating": {
    "list": [
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "description": "Log level filter",
        "includeAll": true,
        "multi": true,
        "name": "level",
        "options": [
          { "selected": false, "text": "error", "value": "error" },
          { "selected": false, "text": "warning", "value": "warning" },
          { "selected": true, "text": "info", "value": "info" },
          { "selected": false, "text": "debug", "value": "debug" }
        ],
        "query": "error,warning,info,debug",
        "type": "custom"
      },
      {
        "current": { "selected": true, "text": "All", "value": ".*" },
        "description": "Logger name filter",
        "includeAll": true,
        "multi": true,
        "name": "logger",
        "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
        "definition": "label_values({job=\"corridorkey\"}, logger)",
        "query": "label_values({job=\"corridorkey\"}, logger)",
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "CorridorKey — Log Explorer",
  "uid": "corridorkey-logs",
  "version": 1
}
